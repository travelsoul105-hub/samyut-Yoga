# ============================================================
# Samyut Yoga Platform — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================================

# ------------------------------------------------------------
# SUPABASE (Required)
# Get from: https://supabase.com > Project Settings > API
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------------------------------------------------------------
# SANITY CMS (Required for Blog)
# Get from: https://sanity.io > Manage > API
# ------------------------------------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your-sanity-api-token

# ------------------------------------------------------------
# MUX VIDEO (Required for LMS lessons)
# Get from: https://dashboard.mux.com > Settings > API Access Tokens
# ------------------------------------------------------------
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret

# ------------------------------------------------------------
# RESEND (Required for transactional emails)
# Get from: https://resend.com > API Keys
# Add domain samyutyoga.com in Resend dashboard
# ------------------------------------------------------------
RESEND_API_KEY=re_your-api-key-here

# ------------------------------------------------------------
# RAZORPAY (Required for Indian payments)
# Get from: https://dashboard.razorpay.com > Settings > API Keys
# ------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_live_your-key-id
RAZORPAY_KEY_SECRET=your-razorpay-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_your-key-id

# ------------------------------------------------------------
# STRIPE (Required for international payments)
# Get from: https://dashboard.stripe.com > Developers > API Keys
# ------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key

# ------------------------------------------------------------
# SITE CONFIG
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://samyutyoga.com

# ------------------------------------------------------------
# OPTIONAL: Next.js build
# ------------------------------------------------------------
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://samyutyoga.com
